{
  "ignoreCommand": "git diff HEAD^ HEAD --quiet -- . ':(exclude)docs'",
  "rewrites": [
    {
      "source": "/docs",
      "destination": "https://botflowio.mintlify.dev/docs"
    },
    {
      "source": "/docs/:match*",
      "destination": "https://botflowio.mintlify.dev/docs/:match*"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/blog-writer",
      "schedule": "0 */12 * * *"
    },
    {
      "path": "/api/cron/sandbox-reaper",
      "schedule": "30 9 * * *"
    }
  ]
}
