{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Botflow",
  "theme": "mint",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.ico",
  "colors": {
    "primary": "#1d52f1",
    "light": "#4d7af5",
    "dark": "#1540c9"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Features",
            "pages": [
              "features/workspace",
              "features/ai",
              "features/editor",
              "features/preview",
              "features/convex",
              "features/env-vars",
              "features/github",
              "features/deploy",
              "features/settings",
              "features/troubleshooting"
            ]
          },
          {
            "group": "Community",
            "pages": ["features/explore"]
          },
          {
            "group": "Plans",
            "pages": ["pricing"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://botflow.io/projects",
          "icon": "grid-2"
        },
        {
          "anchor": "Explore",
          "href": "https://botflow.io/explore",
          "icon": "compass"
        }
      ]
    }
  },
  "footerSocials": {
    "x": "https://x.com/botflow_io",
    "github": "https://github.com/AWKohler"
  }
}
