{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Botflow",
  "theme": "mint",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/logo/light.svg",
  "colors": {
    "primary": "#1d52f1",
    "light": "#4d7af5",
    "dark": "#1540c9"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Features",
            "pages": ["features/editor", "features/ai", "features/deploy"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://botflow.io/projects",
          "icon": "grid-2"
        }
      ]
    }
  },
  "footerSocials": {
    "x": "https://x.com/botflow_io",
    "github": "https://github.com/AWKohler"
  }
}
